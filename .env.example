# ==========================================
# n8n Environment Variables Configuration
# ==========================================
# Copy this file to .env and fill in your values.
# These variables are referenced in the workflow JSONs via {{$env.VAR_NAME}}.
# n8n must be started with --env or configured to load these variables.
# ==========================================

# --- OpenRouter AI ---
# Get your API key from https://openrouter.ai/keys
OPENROUTER_API_KEY=sk-or-v1-your-key-here

# --- Google Sheets ---
# The ID from your Google Sheet URL (the long string in /spreadsheets/d/.../edit)
GOOGLE_SHEET_ID=your-google-sheet-id-here

# --- Telegram Bot ---
# Create a bot via @BotFather on Telegram and copy the token
TELEGRAM_BOT_TOKEN=1234567890:ABCdefGHIjklmNOPqrStuVWXyz
# Your Telegram user ID (message @userinfobot to get it)
TELEGRAM_CHAT_ID=123456789

# --- WhatsApp (Green API) ---
# Sign up at https://green-api.com and create an instance
GREEN_API_INSTANCE=1101000001
GREEN_API_TOKEN=your-green-api-token-here
# Target phone number in international format including @c.us suffix
WHATSAPP_CHAT_ID=923001234567@c.us
